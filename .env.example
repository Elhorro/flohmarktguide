# Supabase - Public Keys (Build + Runtime)
# Verfügbar im Supabase Dashboard: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Site URL - Public (Build + Runtime)
# Die öffentliche URL deiner Anwendung
NEXT_PUBLIC_SITE_URL=https://flohmarktguide.com

# Supabase Service Role Key - Secret (Runtime only)
# NUR auf dem Server nutzen! NIEMALS in Frontend-Code verwenden!
# Verfügbar im Supabase Dashboard: Settings > API (Service Role Key)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin Secret - Custom (Runtime only)
# Dein Custom Admin-Geheimnis für Admin-Operationen
ADMIN_SECRET=your-admin-secret-here

# Hinweis: Lokales Testen mit: cp .env.example .env.local